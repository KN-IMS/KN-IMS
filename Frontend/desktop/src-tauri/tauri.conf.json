{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KN-IG Console",
  "version": "0.1.0",
  "identifier": "com.kn-ig.console",
  "build": {
    "frontendDist": "../../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "KN-IG Console",
        "width": 360,
        "height": 460,
        "minWidth": 360,
        "minHeight": 460,
        "resizable": false,
        "center": true,
        "backgroundColor": "#ffffff"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
