# FIM Agent transport 설정
# 위치: /etc/fim_monitor/fim.env
# 권한: sudo chown root:root fim.env && sudo chmod 640 fim.env

FIM_SERVER_HOST=192.168.64.1
FIM_SERVER_PORT=9000
FIM_CA_CRT=/etc/fim_monitor/certs/ca.crt
FIM_AGENT_CRT=/etc/fim_monitor/certs/agent.crt
FIM_AGENT_KEY=/etc/fim_monitor/certs/agent.key
